# Project Bluebird — 환경 변수 템플릿
# 이 파일을 복사: cp .env.local.example .env.local
# 실제 값은 .env.local 에만 채워 넣고, 절대 커밋하지 말 것.

# ─── Supabase (필수) ──────────────────────────────────────
# Supabase 대시보드 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Gemini (필수) ────────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=

# ─── 운영·디버그 (선택) ───────────────────────────────────
# RLS 감사 스크립트(scripts/rls-audit.ts) 전용. 절대 클라이언트로 노출 금지.
# Supabase 대시보드 → Settings → API → service_role key.
# Production 프로젝트에서 실행 금지 — 스테이징/dev에서만.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini 분석 raw response를 stderr로 출력 (파싱 실패 디버깅용).
# '1' 로 설정하면 활성. production 에서는 절대 설정하지 말 것.
# DEBUG_ANALYZE=1
